{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vision Lab",
  "version": "0.1.0",
  "identifier": "com.vitavision.vision-lab",
  "build": {
    "beforeDevCommand": "bun run --cwd ui dev",
    "beforeBuildCommand": "bun run --cwd ui build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vision Lab",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
