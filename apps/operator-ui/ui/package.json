{
  "name": "vision-lab-operator-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
